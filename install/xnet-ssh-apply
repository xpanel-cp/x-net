#!/usr/bin/env bash
# ============================================================
#  xnet-ssh-apply — applies the panel's SSH subsystem settings to the real
#  system services (Dropbear, stunnel/TLS, SlowDNS, BadVPN/UDPGW, WebSocket,
#  and per-instance sshd config files) and (re)starts/stops each unit to match.
#
#  The panel (running as the unprivileged "xnet" user) writes its settings to
#  the JSON file and invokes this script via:
#     sudo -n /opt/xnet/xnet-ssh-apply <settings-json-path>
#
#  CRITICAL: This script NEVER modifies AllowGroups in any sshd config file.
#  Only the Port directive is updated — protocol group isolation is preserved.
#
#  Exit codes: 0 = success, 1 = usage/input error, 2 = partial apply error
# ============================================================
# XNET_SSH_APPLY_VERSION=6   (v6: remove legacy stunnel xnet-ssh.conf that hardcoded connect=:22; TLS forwards only to sshd_tls:2223)
set -uo pipefail

SETTINGS_FILE="${1:-/opt/xnet/ssh-settings.json}"

log() { echo "[xnet-ssh-apply] $*"; }

[ -f "$SETTINGS_FILE" ] || { log "settings file not found: $SETTINGS_FILE"; exit 1; }

# --- JSON readers ------------------------------------------------------------
have_jq=0
command -v jq >/dev/null 2>&1 && have_jq=1

jget() {
  local path="$1" def="${2:-}"
  local val=""
  if [ "$have_jq" = "1" ]; then
    val="$(jq -r "$path // empty" "$SETTINGS_FILE" 2>/dev/null)"
  else
    val="$(python3 - "$SETTINGS_FILE" "$path" <<'PY' 2>/dev/null
import json,sys
data=json.load(open(sys.argv[1]))
path=sys.argv[2].lstrip('.').split('.')
cur=data
for k in path:
    if isinstance(cur,dict) and k in cur:
        cur=cur[k]
    else:
        cur=""
        break
print("" if cur is None else cur)
PY
)"
  fi
  [ -z "$val" ] && val="$def"
  echo "$val"
}

HAD_ERROR=0

# unit_exists returns 0 if a systemd unit is installed on this host (either as a
# unit file or a loaded/generated unit), 1 otherwise. Used to avoid treating an
# optional, not-installed unit (e.g. a WS sshd that is panel-managed in-process)
# as a hard apply failure.
unit_exists() {
  local unit="$1"
  # Normalize: allow callers to pass "name" or "name.service".
  case "$unit" in
    *.*) : ;;
    *)   unit="${unit}.service" ;;
  esac
  systemctl list-unit-files "$unit" >/dev/null 2>&1 \
    && systemctl list-unit-files "$unit" 2>/dev/null | grep -q "$unit" && return 0
  systemctl cat "$unit" >/dev/null 2>&1
}

restart_unit() {
  local unit="$1"
  systemctl daemon-reload 2>/dev/null || true
  systemctl enable "$unit" >/dev/null 2>&1 || true
  if ! systemctl restart "$unit" >/dev/null 2>&1; then
    systemctl start "$unit" >/dev/null 2>&1 || { log "warning: failed to start $unit"; HAD_ERROR=1; }
  fi
}

# restart_first_existing restarts the first installed unit from the given list.
# If none of the candidate units exist, it does NOT flag HAD_ERROR — the caller
# treats a missing optional unit as "nothing to do" (returns non-zero so callers
# can branch). Returns 0 if a unit was found and a restart attempted.
restart_first_existing() {
  local u
  for u in "$@"; do
    if unit_exists "$u"; then
      restart_unit "$u"
      return 0
    fi
  done
  return 1
}

stop_unit() {
  local unit="$1"
  systemctl stop "$unit" >/dev/null 2>&1 || true
  systemctl disable "$unit" >/dev/null 2>&1 || true
  case "$unit" in
    slowdns)      pkill -f dns-server >/dev/null 2>&1 || true ;;
    badvpn-udpgw) pkill -f badvpn-udpgw >/dev/null 2>&1 || true ;;
  esac
}

# open_fw_port opens a TCP port in whichever firewall is active (ufw or
# firewalld). Best-effort and idempotent; does nothing if no managed firewall is
# running. Used so a port change from the panel never silently locks out access.
open_fw_port() {
  local p="$1"
  [[ "$p" =~ ^[0-9]+$ ]] || return 0
  if command -v ufw >/dev/null 2>&1 && ufw status 2>/dev/null | grep -q "Status: active"; then
    ufw allow "${p}/tcp" >/dev/null 2>&1 || true
  fi
  if command -v firewall-cmd >/dev/null 2>&1 && firewall-cmd --state >/dev/null 2>&1; then
    firewall-cmd --permanent --add-port="${p}/tcp" >/dev/null 2>&1 || true
    firewall-cmd --reload >/dev/null 2>&1 || true
  fi
}

# ensure_login_group_membership is an ANTI-LOCKOUT safety net. The main sshd is
# protected by `AllowGroups ssh-tcp-users` (added by xnet-install-sshd.sh). When
# the panel changes the OpenSSH port we restart sshd, which makes that directive
# take effect. If the administrative login user is NOT in the allowed group, the
# restart would lock them out. So, whenever sshd_config carries an AllowGroups
# line that includes ssh-tcp-users, guarantee that root (the universal fallback
# admin) — and the panel's configured SSH admin, if any — belong to that group.
# This NEVER edits the AllowGroups directive itself (only group membership), so
# protocol isolation is preserved.
ensure_login_group_membership() {
  local cfg=/etc/ssh/sshd_config
  [ -f "$cfg" ] || return 0
  # Only act when the main sshd actually restricts logins by group.
  grep -qiE '^[[:space:]]*AllowGroups[[:space:]].*\bssh-tcp-users\b' "$cfg" || return 0

  command -v groupadd >/dev/null 2>&1 && groupadd -f ssh-tcp-users >/dev/null 2>&1 || true

  local u
  for u in root "${XNET_SSH_ADMIN_USER:-}"; do
    [ -n "$u" ] || continue
    id "$u" >/dev/null 2>&1 || continue
    if ! id -nG "$u" 2>/dev/null | tr ' ' '\n' | grep -qx ssh-tcp-users; then
      usermod -aG ssh-tcp-users "$u" >/dev/null 2>&1 \
        && log "anti-lockout: added '$u' to ssh-tcp-users (AllowGroups is active)" \
        || log "warning: could not add '$u' to ssh-tcp-users"
    fi
  done
}

# --- Helper: Update Port directive in sshd config (preserves AllowGroups) ----
update_sshd_port() {
  local config_file="$1" new_port="$2"
  [ -f "$config_file" ] || return 0
  if grep -q "^Port " "$config_file"; then
    sed -i "s/^Port [0-9]\+/Port $new_port/" "$config_file"
  else
    sed -i "1i Port $new_port" "$config_file"
  fi
}

# --- OpenSSH (main sshd on port 22) -----------------------------------------
apply_openssh() {
  local enabled port maxs
  enabled="$(jget '.openssh.enabled' 'true')"
  port="$(jget '.openssh.port' '22')"
  maxs="$(jget '.openssh.maxSessions' '10')"
  [ -f /etc/ssh/sshd_config ] || return 0

  if [[ "$port" =~ ^[0-9]+$ ]]; then
    update_sshd_port /etc/ssh/sshd_config "$port"
  fi

  # Modern Ubuntu/Debian default to SSH socket activation (ssh.socket). The
  # listening port is then controlled by the socket's ListenStream and the
  # `Port` directive in sshd_config is ignored. Running BOTH ssh.socket and a
  # standalone ssh.service that bind the same port causes systemd to flap (the
  # daemon is repeatedly stopped/started), which surfaces to clients as
  # "kex_exchange_identification: Connection reset" — i.e. you cannot log in on
  # the new port even though everything looks configured.
  #
  # To make a custom port reliable we standardize on EXACTLY ONE mechanism:
  # disable socket activation and let the classic ssh.service bind the Port from
  # sshd_config (which we set above). This is the documented, stable way to run
  # sshd on a custom port on socket-activated distros.
  if [[ "$port" =~ ^[0-9]+$ ]]; then
    local sock=""
    if systemctl cat ssh.socket >/dev/null 2>&1; then sock="ssh.socket"
    elif systemctl cat sshd.socket >/dev/null 2>&1; then sock="sshd.socket"; fi
    if [ -n "$sock" ]; then
      # Remove any stale xnet ListenStream drop-in written by older versions.
      rm -f "/etc/systemd/system/${sock}.d/xnet-port.conf" 2>/dev/null || true
      rmdir "/etc/systemd/system/${sock}.d" 2>/dev/null || true
      # Stop + disable socket activation so the port is freed for ssh.service and
      # the two mechanisms can no longer fight over it.
      systemctl disable --now "$sock" >/dev/null 2>&1 || true
      systemctl daemon-reload 2>/dev/null || true
      log "OpenSSH: disabled ${sock} (socket activation) — using classic ssh.service on port ${port}"
    fi
  fi
  if [[ "$maxs" =~ ^[0-9]+$ ]] && [ "$maxs" -gt 0 ]; then
    if grep -qiE '^[#[:space:]]*MaxSessions[[:space:]]' /etc/ssh/sshd_config; then
      sed -i -E "s/^[#[:space:]]*MaxSessions[[:space:]].*/MaxSessions ${maxs}/I" /etc/ssh/sshd_config
    else
      echo "MaxSessions ${maxs}" >> /etc/ssh/sshd_config
    fi
  fi
  grep -qiE '^[[:space:]]*AllowTcpForwarding[[:space:]]+yes' /etc/ssh/sshd_config || echo "AllowTcpForwarding yes" >> /etc/ssh/sshd_config

  # ANTI-LOCKOUT: before (re)starting sshd on the new port, make sure the admin
  # is still permitted by AllowGroups and that the new port is reachable through
  # any active firewall. Without these, a port change can lock the operator out.
  ensure_login_group_membership
  if [ "$enabled" = "true" ] && [[ "$port" =~ ^[0-9]+$ ]]; then
    open_fw_port "$port"
  fi

  local unit="ssh"
  systemctl list-unit-files ssh.service 2>/dev/null | grep -q ssh.service || unit="sshd"
  if [ "$enabled" = "true" ]; then restart_unit "$unit"; fi
  log "OpenSSH: port=${port} maxSessions=${maxs}"
}

# --- WebSocket sshd (sshd_config_ws) -----------------------------------------
apply_ws_sshd() {
  local enabled port
  enabled="$(jget '.websocket.enabled' 'false')"
  port="$(jget '.websocket.port' '2222')"
  [[ "$port" =~ ^[0-9]+$ ]] || port=2222

  if [ -f /etc/ssh/sshd_config_ws ]; then
    update_sshd_port /etc/ssh/sshd_config_ws "$port"
  fi

  if [ "$enabled" = "true" ]; then
    # The WS sshd unit is named sshd-ws on a standard install (see
    # xnet-install-sshd.sh). Older/alternate deployments may use xnet-ws.
    # If neither unit is installed, the WebSocket path is served by the
    # panel-managed in-process proxy and there is nothing to restart — that is
    # NOT an error, so do not flag HAD_ERROR.
    if ! restart_first_existing sshd-ws xnet-ws; then
      log "WebSocket sshd: no sshd-ws/xnet-ws unit installed (panel-managed WS proxy) — skipping service restart"
    fi
  else
    unit_exists sshd-ws && stop_unit sshd-ws
    unit_exists xnet-ws && stop_unit xnet-ws
  fi

  # Open firewall for the WS listener port (panel-managed WebSocket proxy)
  local ws_listen_port
  ws_listen_port="$(jget '.websocket.listenPort' '8880')"
  if [ "$enabled" = "true" ] && [[ "$ws_listen_port" =~ ^[0-9]+$ ]]; then
    if command -v ufw >/dev/null 2>&1 && ufw status 2>/dev/null | grep -q "Status: active"; then
      ufw allow "${ws_listen_port}/tcp" >/dev/null 2>&1 || true
    elif command -v firewall-cmd >/dev/null 2>&1 && firewall-cmd --state >/dev/null 2>&1; then
      firewall-cmd --permanent --add-port="${ws_listen_port}/tcp" >/dev/null 2>&1 || true
      firewall-cmd --reload >/dev/null 2>&1 || true
    fi
  fi
  log "WebSocket sshd: port=${port} enabled=${enabled}"
}

# --- TLS sshd (sshd_config_tls) + stunnel ------------------------------------
apply_tls() {
  local enabled port cert key
  enabled="$(jget '.tlsSsl.enabled' 'false')"
  port="$(jget '.tlsSsl.port' '2083')"
  cert="$(jget '.tlsSsl.certPath' '')"
  key="$(jget '.tlsSsl.keyPath' '')"
  local ws_tls_port
  ws_tls_port="$(jget '.tlsSsl.wsTlsPort' '2084')"

  # sshd_tls internal port (stunnel connects to this for direct SSH-TLS)
  local sshd_tls_port="2223"
  [[ "$port" =~ ^[0-9]+$ ]] || port=2083
  [[ "$ws_tls_port" =~ ^[0-9]+$ ]] || ws_tls_port=2084

  # Heal legacy installs: older installers shipped /etc/stunnel/xnet-ssh.conf
  # with a hardcoded `connect = 127.0.0.1:22`. stunnel loads every *.conf in
  # /etc/stunnel, so that stale file keeps dialing the main sshd and breaks the
  # moment the OpenSSH port changes. We forward TLS only to the dedicated
  # sshd_tls (127.0.0.1:2223) via stunnel.conf, so remove the legacy file.
  rm -f /etc/stunnel/xnet-ssh.conf 2>/dev/null || true

  if [ -f /etc/ssh/sshd_config_tls ]; then
    update_sshd_port /etc/ssh/sshd_config_tls "$sshd_tls_port"
  fi

  if [ "$enabled" != "true" ]; then
    stop_unit stunnel4
    stop_unit sshd-tls 2>/dev/null || true
    log "TLS/stunnel: disabled"
    return 0
  fi

  # Restart sshd-tls
  unit_exists sshd-tls && restart_unit sshd-tls

  # Configure stunnel with two sections:
  # 1. ssh-tls-direct: accepts on TLS port, forwards raw SSH to sshd_tls
  # 2. ssh-tls-payload: accepts on WS-TLS port, forwards HTTP payload to WSProxy
  mkdir -p /etc/stunnel
  if [ -z "$cert" ] || [ -z "$key" ] || [ ! -f "$cert" ] || [ ! -f "$key" ]; then
    cert=/etc/stunnel/xnet-self.crt
    key=/etc/stunnel/xnet-self.key
    if [ ! -f "$cert" ] || [ ! -f "$key" ]; then
      openssl req -x509 -newkey rsa:2048 -keyout "$key" -out "$cert" -days 3650 -nodes \
        -subj "/CN=xnet" >/dev/null 2>&1 || true
    fi
  fi

  # Determine WSProxy port (where HTTP-payload TLS traffic goes)
  local ws_proxy_port
  ws_proxy_port="$(jget '.websocket.port' '80')"

  cat > /etc/stunnel/stunnel.conf <<CONF
pid = /var/run/stunnel4.pid

[ssh-tls-direct]
accept = ${port}
connect = 127.0.0.1:${sshd_tls_port}
cert = ${cert}
key = ${key}

[ssh-tls-payload]
accept = ${ws_tls_port}
connect = 127.0.0.1:${ws_proxy_port}
cert = ${cert}
key = ${key}
CONF
  [ -f /etc/default/stunnel4 ] && sed -i 's/^ENABLED=.*/ENABLED=1/' /etc/default/stunnel4 2>/dev/null || true
  restart_unit stunnel4
  log "TLS/stunnel: direct_port=${port}->sshd_tls:${sshd_tls_port}, ws_tls_port=${ws_tls_port}->ws_proxy:${ws_proxy_port}"
}

# --- SlowDNS sshd (sshd_config_dns) + slowdns service ------------------------
apply_slowdns() {
  local enabled port ns key bin
  enabled="$(jget '.slowdns.enabled' 'false')"
  port="$(jget '.slowdns.port' '2224')"
  ns="$(jget '.slowdns.nsDomain' '')"
  key="$(jget '.slowdns.privateKey' '')"
  local dns_port
  dns_port="$(jget '.slowdns.dnsPort' '5300')"

  # Update sshd_config_dns Port
  [[ "$port" =~ ^[0-9]+$ ]] || port=2224
  if [ -f /etc/ssh/sshd_config_dns ]; then
    update_sshd_port /etc/ssh/sshd_config_dns "$port"
  fi

  if [ "$enabled" != "true" ]; then
    stop_unit slowdns
    stop_unit sshd-dns 2>/dev/null || true
    log "SlowDNS: disabled"
    return 0
  fi

  # Restart sshd-dns
  unit_exists sshd-dns && restart_unit sshd-dns

  bin="$(command -v dns-server || command -v sldns-server || echo /usr/local/bin/dns-server)"
  if [ ! -x "$bin" ]; then
    if [ "$(uname -m)" = "x86_64" ]; then
      log "SlowDNS: fetching prebuilt server binary..."
      curl -fsSL "https://raw.githubusercontent.com/khaledagn/DNS-AGN/main/files/dns-server" -o /usr/local/bin/dns-server 2>/dev/null \
        && chmod +x /usr/local/bin/dns-server && bin=/usr/local/bin/dns-server
    fi
  fi
  if [ ! -x "$bin" ] || [ -z "$ns" ]; then
    log "SlowDNS: server binary or nsDomain missing — service not started"
    return 0
  fi
  mkdir -p /etc/slowdns
  [ -n "$key" ] && printf '%s' "$key" > /etc/slowdns/server.key
  cat > /etc/systemd/system/slowdns.service <<UNIT
[Unit]
Description=SlowDNS server (xnet-managed)
After=network.target
[Service]
ExecStart=${bin} -udp :${dns_port} -privkey-file /etc/slowdns/server.key ${ns} 127.0.0.1:${port}
Restart=on-failure
[Install]
WantedBy=multi-user.target
UNIT
  pkill -f dns-server >/dev/null 2>&1 || true
  sleep 0.3
  restart_unit slowdns
  log "SlowDNS: dns_port=${dns_port} sshd_port=${port} ns=${ns}"
}

# --- Dropbear ----------------------------------------------------------------
apply_dropbear() {
  local enabled port
  enabled="$(jget '.dropbear.enabled' 'false')"
  port="$(jget '.dropbear.port' '444')"
  if [ "$enabled" != "true" ]; then stop_unit dropbear; log "Dropbear: disabled"; return 0; fi
  [[ "$port" =~ ^[0-9]+$ ]] || port=444

  if [ -d /etc/default ]; then
    {
      echo "NO_START=0"
      echo "DROPBEAR_PORT=${port}"
      echo "DROPBEAR_EXTRA_ARGS="
    } > /etc/default/dropbear
  fi

  if systemctl list-unit-files dropbear.service 2>/dev/null | grep -q dropbear.service; then
    restart_unit dropbear
  else
    local bin; bin="$(command -v dropbear || echo /usr/sbin/dropbear)"
    cat > /etc/systemd/system/dropbear.service <<UNIT
[Unit]
Description=Dropbear SSH server (xnet-managed)
After=network.target
[Service]
ExecStart=${bin} -F -E -p ${port}
Restart=on-failure
[Install]
WantedBy=multi-user.target
UNIT
    restart_unit dropbear
  fi
  log "Dropbear: port=${port}"
}

# --- BadVPN UDPGW ------------------------------------------------------------
apply_udpgw() {
  local enabled port bin
  enabled="$(jget '.udpgw.enabled' 'false')"
  port="$(jget '.udpgw.port' '7300')"
  if [ "$enabled" != "true" ]; then stop_unit badvpn-udpgw; log "UDPGW: disabled"; return 0; fi
  [[ "$port" =~ ^[0-9]+$ ]] || port=7300
  bin="$(command -v badvpn-udpgw || echo /usr/bin/badvpn-udpgw)"
  [ -x "$bin" ] || { log "UDPGW: badvpn-udpgw binary not found — skipping"; return 0; }
  cat > /etc/systemd/system/badvpn-udpgw.service <<UNIT
[Unit]
Description=BadVPN UDPGW for SSH UDP forwarding (xnet-managed)
After=network.target
[Service]
ExecStart=${bin} --listen-addr 127.0.0.1:${port} --max-clients 512 --max-connections-for-client 10
Restart=on-failure
[Install]
WantedBy=multi-user.target
UNIT
  pkill -f badvpn-udpgw >/dev/null 2>&1 || true
  sleep 0.3
  restart_unit badvpn-udpgw
  log "UDPGW: port=${port}"
}

# --- Main --------------------------------------------------------------------
main() {
  apply_openssh
  apply_ws_sshd
  apply_tls
  apply_slowdns
  apply_dropbear
  apply_udpgw
  log "apply complete"
}

main

if [ "$HAD_ERROR" -ne 0 ]; then
  exit 2
fi
exit 0
